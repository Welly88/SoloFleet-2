{
  "expo": {
    "name": "Solo Fleet Development",
    "slug": "solofleet",
    "owner": "solo-lmp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/soloo.png",
    "scheme": "Solo-Fleet",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.solofleet.solofleet-2"
    },
    "android": {
      "package": "com.solofleet.solofleet",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/soloo.png",
        "monochromeImage": "./assets/images/soloo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/soloo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/soloo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": false
    },
    "extra": {
      "defaultAppIconSet": true,
      "selectedIconUrl": "https://sqgedrruthtbkskkjeqa.supabase.co/storage/v1/object/public/projects/dcf2d89c-1967-4d29-9b21-135487f98529/fs/assets/images/icon.png?t=1778653918017",
      "router": {},
      "eas": {
        "projectId": "05d5c3f4-b558-4696-8387-60b8b7d4243c"
      }
    }
  }
}
